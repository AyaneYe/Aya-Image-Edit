{
  "id": "io.aya.imageedit",
  "name": "AyaImageEdit",
  "version": "1.0.0",
  "main": "index.html",
  "manifestVersion": 5,
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": "all"
    },
    "webview": {
      "allow": "yes",
      "allowLocalRendering": "yes",
      "enableMessageBridge": "localAndRemote",
      "domains": "all"
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "ayaImageEdit",
      "label": {
        "default": "AyaImageEdit"
      },
      "minimumSize": {
        "width": 320,
        "height": 260
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 560
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 680
      },
      "icons": [
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_D.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "dark",
            "darkest"
          ],
          "species": [
            "generic"
          ]
        },
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_N.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "lightest",
            "light"
          ],
          "species": [
            "generic"
          ]
        }
      ]
    }
  ],
  "host": [
    {
      "app": "PS",
      "minVersion": "26.8.0"
    }
  ],
  "icons": [
    {
      "width": 32,
      "height": 32,
      "path": "icons/icon_D.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "dark",
        "darkest"
      ],
      "species": [
        "generic"
      ]
    },
    {
      "width": 32,
      "height": 32,
      "path": "icons/icon_N.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "lightest",
        "light"
      ],
      "species": [
        "generic"
      ]
    }
  ]
}
