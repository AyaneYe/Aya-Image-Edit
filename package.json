{
  "name": "com.adobe.uxp.starter.react",
  "version": "1.0.0",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "build:pack": "pnpm build && pnpm pack:ccx",
    "pack:ccx": "cd dist && zip -X -r -9 -FS ../io.aya.imageedit.ccx . -x \"*.DS_Store\"",
    "uxp:load": "cd dist && uxp plugin load",
    "uxp:reload": "cd dist && uxp plugin reload",
    "uxp:debug": "cd dist && uxp plugin debug",
    "uxptool:debug": "pnpm --allow-build=@adobe-fixed-uxp/uxp-devtools-helper dlx @bubblydoo/uxp-cli open-devtools --plugin-path ./dist"
  },
  "author": "Adobe Inc",
  "license": "Apache-2.0",
  "devDependencies": {
    "@adobe-uxp-types/photoshop": "^0.1.7",
    "@adobe-uxp-types/uxp": "^0.1.3",
    "@bubblydoo/vite-uxp-plugin": "^0.0.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.10"
  },
  "dependencies": {
    "@bubblydoo/uxp-toolkit": "^0.0.16",
    "@bubblydoo/uxp-toolkit-react": "^0.0.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.6"
  },
  "resolutions": {
    "acorn": "npm:acorn-with-stage3"
  }
}
